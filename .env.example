# Copy this file to .env and fill in your actual values
# .env is gitignored and will not be committed

# ===== GENERATION BACKEND =====
# Set to 'claude' (default) to use the Anthropic API, or 'ollama' to use a
# local model served by Ollama (no API key required, no cost).
GENERATION_BACKEND=claude

# Ollama model tag — only used when GENERATION_BACKEND=ollama.
# Run `ollama pull phi4-mini` before switching to this backend.
OLLAMA_MODEL=phi4-mini

# ===== ANTHROPIC API =====
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-api-key-here

# Model selection
CLAUDE_MODEL=claude-sonnet-4-6

# Cost control
MAX_TOKENS_PER_RESPONSE=500
MAX_COST_PER_QUERY_USD=0.05

# ===== PATHS =====
PDF_LIBRARY_PATH=./zotero/library/path
DATA_DIR=./data

# ===== EMBEDDING CONFIGURATION =====
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
USE_LOCAL_EMBEDDINGS=true

# ===== CHUNKING STRATEGY =====
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ===== RETRIEVAL =====
TOP_K_CHUNKS=5
USE_RERANKING=false

# ===== QUERY DECOMPOSITION =====
# When true, complex queries are split into sub-questions before retrieval;
# results from each sub-question are merged and deduplicated before generation.
QUERY_DECOMPOSITION=false
QUERY_DECOMPOSITION_MODEL=claude-haiku-4-5-20251001

# ===== VECTOR STORE =====
VECTOR_STORE_TYPE=faiss

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_assistant.log

# ===== EVALUATION =====
NUM_GENERATED_QUESTIONS=20
TEST_GEN_TEMPERATURE=0.7

# Eval questions file used by `pixi run evaluate`.
# If unset, defaults to the newest eval_questions_*.jsonl in data/eval/.
# Switch between datasets by pointing this at a different file, e.g.:
#   data/eval/eval_questions_combined_golden.jsonl  (auto-generated + golden)
#   data/eval/eval_questions_20260414T201725Z.jsonl (auto-generated only)
# EVAL_QUESTIONS_PATH=data/eval/eval_questions_combined_golden.jsonl

# ===== TEST DATA =====
# Path to a PDF used by scripts/test_*.py — relative to project root
TEST_PDF_PATH=data/path/to/your/test.pdf
